# ============================================================
# Data Platform in a Box — переменные окружения
# Скопируй в .env и поправь под себя
# ============================================================

# ----- PostgreSQL -----
POSTGRES_USER=dpib
POSTGRES_PASSWORD=dpib_pass
POSTGRES_DB=dpib
POSTGRES_PORT=5432

# ----- ClickHouse -----
CLICKHOUSE_DB=dpib
CLICKHOUSE_USER=dpib
CLICKHOUSE_PASSWORD=dpib_pass
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_METRICS_PORT=9363

# ----- Redis (broker для Celery + ad-hoc очереди) -----
REDIS_PORT=6379

# ----- Monitoring -----
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ----- Airflow -----
AIRFLOW_UI_PORT=8080
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
# UID для bind-mount volumes (на Linux/WSL — твой uid, обычно 1000; на macOS — 50000)
AIRFLOW_UID=50000
# Секреты — в проде сгенерить новые, для лабы дефолтных хватит
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=46BKJoQYlPPOexq0OhDZnIlNepKFf87WFwLbfzqDDho=
AIRFLOW_JWT_SECRET=dpib-jwt-secret-change-me

# ----- HH ingest -----
# TLS/browser profile для curl_cffi. Обычно chrome120 достаточно.
DPIB_HH_IMPERSONATE=chrome120
# Лимит HTML-страниц на одну комбинацию role/region, если публичный API HH вернул 401/403.
# 5 страниц обычно дают до ~100 вакансий на комбинацию без агрессивного скрейпинга.
DPIB_HH_HTML_FALLBACK_MAX_PAGES=5
# Догружать detail-страницы вакансий из HTML fallback: описание, опыт, занятость, навыки.
DPIB_HH_FETCH_DETAILS=true
# Верхний лимит detail-страниц на одну комбинацию role/region.
DPIB_HH_DETAIL_MAX_PER_COMBO=100
# Пауза между detail-запросами, чтобы не долбить источник.
DPIB_HH_DETAIL_PAUSE_MIN_SEC=0.2
DPIB_HH_DETAIL_PAUSE_MAX_SEC=0.6

# ----- Профили для запуска -----
# Альтернатива make-флагу: docker compose --profile core --profile monitoring up -d
COMPOSE_PROFILES=core,monitoring,orchestration
